extends: default

# Lista de reglas personalizadas (opcionales)
rules:
  # No permitir tabulaciones (recomendado true)
  indentation:
    spaces: 2
    indent-sequences: consistent
  
  # No permitir líneas demasiado largas (recomendado 120)
  line-length:
    max: 120

  quoted-strings:
    quote-type: any
    required: false
